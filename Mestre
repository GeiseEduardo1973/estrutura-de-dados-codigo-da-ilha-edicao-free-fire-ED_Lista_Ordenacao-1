using namespace std; 

// REQUISITO: Definição da struct 
struct Componente {
    string nome;
    string tipo;
    int prioridade;
};

// --- Protótipos das funções --- 
void bubbleSortNome(vector<Componente>& v, int& comp);
void insertionSortTipo(vector<Componente>& v, int& comp);
void selectionSortPrioridade(vector<Componente>& v, int& comp);
int buscaBinariaPorNome(const vector<Componente>& v, string alvo, int& comp);
void mostrarComponentes(const vector<Componente>& v);

int main() {
    vector<Componente> torre;
    int total, opcao;
    bool ordenadoPorNome = false;

    cout << "--- MISSAO FINAL: ESCAPE DA ILHA ---" << endl;

    // 2. Entrada de Dados 
    cout << "Quantos componentes cadastrar (max 20)? ";
    cin >> total;
    cin.ignore();

    for (int i = 0; i < total; i++) {
        Componente c;
        cout << "\nComponente " << i + 1 << ":" << endl;
        cout << "Nome: ";
        getline(cin, c.nome); 
        cout << "Tipo (controle/suporte/propulsao): ";
        getline(cin, c.tipo);
        cout << "Prioridade (1-10): ";
        cin >> c.prioridade;
        cin.ignore();
        torre.push_back(c);
    }

    do {
        int comparacoes = 0; // Resetar a cada operação 
        // 3. Menu Interativo [cite: 31]
        cout << "\n--- MENU DE ESTRATEGIA ---" << endl;
        cout << "1. Ordenar por Nome (Bubble Sort)" << endl;
        cout << "2. Ordenar por Tipo (Insertion Sort)" << endl;
        cout << "3. Ordenar por Prioridade (Selection Sort)" << endl;
        cout << "4. Buscar Componente-Chave (Busca Binaria)" << endl;
        cout << "5. Sair" << endl;
        cout << "Escolha: ";
        cin >> opcao;
        cin.ignore();

        clock_t inicio = clock(); 

        switch (opcao) {
            case 1:
                bubbleSortNome(torre, comparacoes);
                ordenadoPorNome = true;
                break;
            case 2:
                insertionSortTipo(torre, comparacoes); 
                ordenadoPorNome = false;
                break;
            case 3:
                selectionSortPrioridade(torre, comparacoes);
                ordenadoPorNome = false;
