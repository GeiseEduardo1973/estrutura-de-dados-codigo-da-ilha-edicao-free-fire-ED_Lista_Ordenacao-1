                }
                break;
        }

        clock_t fim = clock();
        double tempo = (double)(fim - inicio) / CLOCKS_PER_SEC;

        if (opcao >= 1 && opcao <= 3) {
            // 5. Feedback de Desempenho 
            cout << "\n--- Desempenho ---" << endl;
            cout << "Comparacoes: " << comparacoes << endl;
            cout << "Tempo: " << fixed << setprecision(6) << tempo << "s" << endl;
            mostrarComponentes(torre); [cite: 27]
        }

    } while (opcao != 5);

    return 0;
}

// --- Implementação das Funções --- 

void bubbleSortNome(vector<Componente>& v, int& comp) {
    int n = v.size();
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            comp++;
            if (v[j].nome > v[j + 1].nome) swap(v[j], v[j + 1]);
        }
    }
}

void insertionSortTipo(vector<Componente>& v, int& comp) {
    int n = v.size();
    for (int i = 1; i < n; i++) {
        Componente pivo = v[i];
        int j = i - 1;
        while (j >= 0 && v[j].tipo > pivo.tipo) {
            comp++;
            v[j + 1] = v[j];
            j--;
        }
        v[j + 1] = pivo;
    }
}

void selectionSortPrioridade(vector<Componente>& v, int& comp) {
    int n = v.size();
    for (int i = 0; i < n - 1; i++) {
        int min = i;
        for (int j = i + 1; j < n; j++) {
            comp++;
            if (v[j].prioridade < v[min].prioridade) min = j;
        }
        swap(v[i], v[min]);
    }
}

int buscaBinariaPorNome(const vector<Componente>& v, string alvo, int& comp) {
    int esq = 0, dir = v.size() - 1;
    while (esq <= dir) {
        int meio = esq + (dir - esq) / 2;
        comp++;
        if (v[meio].nome == alvo) return meio;
        if (v[meio].nome < alvo) esq = meio + 1;
        else dir = meio - 1;
    }
    return -1;
}

void mostrarComponentes(const vector<Componente>& v) {
    cout << "\n" << left << setw(20) << "NOME" << setw(15) << "TIPO" << "PRIORIDADE" << endl;
    cout << string(45, '-') << endl;
    for (const auto& c : v) {
        cout << left << setw(20) << c.nome << setw(15) << c.tipo << c.prioridade << endl;
    }
}